o","id":"igpffm"},"components":[{"tagName":"font","type":"text","attributes":{"dir":"auto","id":"iatyus"},"components":[{"type":"textnode","content":"Desarrollar en el perito valuador las capacidades necesarias para crear "}]}]},{"tagName":"font","attributes":{"dir":"auto","id":"i768yj"},"components":[{"tagName":"font","attributes":{"dir":"auto","id":"ics6tb"},"components":[{"tagName":"b","type":"text","attributes":{"id":"i47ty"},"components":[{"type":"textnode","content":"herramientas personalizadas sin necesidad de ser un programador experto"}]}]}]},{"tagName":"font","attributes":{"dir":"auto","id":"ipkxzg"},"components":[{"tagName":"font","type":"text","attributes":{"dir":"auto","id":"ighgga"},"components":[{"type":"textnode","content":", mediante el uso de"}]}]},{"tagName":"font","attributes":{"dir":"auto","id":"izs64i"},"components":[{"tagName":"font","attributes":{"dir":"auto","id":"i9005i"},"components":[{"tagName":"b","type":"text","attributes":{"id":"ikp8q"},"components":[{"type":"textnode","content":"Vibe Coding y Power BI"}]}]}]},{"tagName":"font","attributes":{"dir":"auto","id":"ihi4ah"},"components":[{"tagName":"font","type":"text","attributes":{"dir":"auto","id":"ird0zg"},"components":[{"type":"textnode","content":", a fin de optimizar procesos técnicos, estructurar información de valoración, analizar datos con mayor claridad y generar visualizaciones útiles para la toma de decisiones profesionales."}]}]}]}]},{"classes":["inicio-card"],"attributes":{"id":"ibrav"},"components":[{"tagName":"h2","type":"heading","attributes":{"id":"i8eqp"},"components":[{"tagName":"i","classes":["fas","fa-list-check"],"attributes":{"id":"ifluj"}},{"type":"textnode","content":" Temas del módulo"}]},{"classes":["texto-completo"],"attributes":{"id":"i8b7tr"},"components":[{"attributes":{"id":"ij2yds"},"components":[{"attributes":{"id":"ib8puj"},"components":[{"attributes":{"id":"icuyb3"},"components":[{"tagName":"strong","type":"text","attributes":{"id":"iol6im"},"components":[{"type":"textnode","content":"Semana 6: Introducción al Vibe Coding para Peritos"}]},{"tagName":"span","type":"text","attributes":{"id":"ia7lj9"},"components":[{"type":"textnode","content":"6 horas"}]}]},{"tagName":"p","type":"text","attributes":{"id":"i74gpt"},"components":[{"type":"textnode","content":"Uso de IA, como GitHub Copilot, para generar código HTML y JavaScript aplicado a calculadoras de depreciación (Ross-Heidecke) o capitalización de rentas."}]}]},{"attributes":{"id":"io562m"},"components":[{"attributes":{"id":"i1116p"},"components":[{"tagName":"strong","type":"text","attributes":{"id":"iq4pj8"},"components":[{"type":"textnode","content":"Semana 7: Dashboards de Mercado con IA"}]},{"tagName":"span","type":"text","attributes":{"id":"iqgd6k"},"components":[{"type":"textnode","content":"6 horas"}]}]},{"tagName":"p","type":"text","attributes":{"id":"i482xj"},"components":[{"type":"textnode","content":"Creación de aplicaciones web sencillas para visualizar mapas de calor de valores de mercado, con apoyo de Power BI."}]}]},{"attributes":{"id":"ia4szv"},"components":[{"attributes":{"id":"im8plh"},"components":[{"tagName":"strong","type":"text","attributes":{"id":"isc0gu"},"components":[{"type":"textnode","content":"Semanas 8 y 9: Integración API y Webhooks"}]},{"tagName":"span","type":"text","attributes":{"id":"ife11f"},"components":[{"type":"textnode","content":"12 horas"}]}]},{"tagName":"p","type":"text","attributes":{"id":"i28xe9"},"components":[{"type":"textnode","content":"Conectar nuestras aplicaciones con bases de datos externas o servicios de mapas para ampliar la automatización y consulta de información valuatoria."}]}]},{"attributes":{"id":"i1efw7"},"components":[{"attributes":{"id":"ivny7o"},"components":[{"tagName":"strong","type":"text","attributes":{"id":"i3jyz7"},"components":[{"type":"textnode","content":"Semana 10: Proyecto integrador"}]},{"tagName":"span","type":"text","attributes":{"id":"iuj8pv"},"components":[{"type":"textnode","content":"6 horas"}]}]},{"tagName":"p","type":"text","attributes":{"id":"iwyb34"},"components":[{"type":"textnode","content":"Aplicación práctica de los conocimientos del módulo en un ejercicio integrador orientado al desarrollo de herramientas y visualizaciones útiles para la valuación profesional."}]}]}]}]}]}]},{"type":"comment","content":" TEMA 1 "},{"classes":["pagina-tema"],"attributes":{"id":"pagina-tema1"},"components":[{"classes":["tema-header"],"components":[{"tagName":"h2","type":"heading","components":[{"tagName":"i","classes":["fas","fa-microchip"]},{"type":"textnode","content":" 1.- Introducción a la IA Generativa en Valuación"}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"Fundamentos de IA Generativa, LLMs y su aplicación en normatividad, ética profesional."}]}]},{"classes":["subtema-card"],"components":[{"tagName":"h3","type":"heading","components":[{"tagName":"i","classes":["fas","fa-brain"]},{"type":"textnode","content":" Fundamentos de IA Generativa"}]},{"classes":["texto-completo"],"components":[{"tagName":"p","type":"text","components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"¿Qué es la Inteligencia Artificial?"}]},{"type":"textnode","content":" La Inteligencia Artificial (IA) es una rama de la informática que desarrolla sistemas capaces de realizar tareas que normalmente requieren inteligencia humana, como el aprendizaje, razonamiento, reconocimiento de patrones y toma de decisiones."}]},{"tagName":"p","type":"text","components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"¿Qué es un LLM (Large Language Model)?"}]},{"type":"textnode","content":" Un LLM (Modelo de Lenguaje de Gran Escala) es un tipo de IA generativa entrenado con grandes cantidades de texto, capaz de comprender, interpretar y generar lenguaje natural de manera coherente, siendo útil para tareas como redacción, análisis de información y procesamiento de textos complejos."}]}]},{"classes":["video-card"],"components":[{"tagName":"i","classes":["fab","fa-youtube"]},{"tagName":"h4","type":"heading","components":[{"type":"textnode","content":"📺 Video: Fundamentos de Inteligencia Artificial"}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"Haz clic para ver el video en YouTube"}]},{"type":"text","classes":["btn-youtube"],"components":[{"tagName":"i","classes":["fab","fa-youtube"]},{"type":"textnode","content":" Ver en YouTube"}]}]}]},{"classes":["subtema-card"],"components":[{"tagName":"h3","type":"heading","components":[{"tagName":"i","classes":["fas","fa-gavel"]},{"type":"textnode","content":" 1.1.- Uso de LLMs (Gemini, ChatGPT, Claude) para análisis de normatividad"}]},{"classes":["texto-completo"],"components":[{"tagName":"p","type":"text","components":[{"type":"textnode","content":"Los Modelos de Lenguaje de Gran Escala (LLMs) constituyen una herramienta de apoyo en el análisis de normatividad aplicable a los avalúos inmobiliarios, permitiendo:"}]},{"tagName":"ul","classes":["lista-viñetas"],"components":[{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Procesar e interpretar de manera eficiente disposiciones legales, reglamentos urbanos y normas técnicas."}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Facilitan la identificación de usos de suelo, restricciones legales, coeficientes de construcción, así como lineamientos establecidos en planes de desarrollo urbano y normativas locales."}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Permiten sintetizar información relevante para su integración en reportes de valuación, mejorando la claridad y consistencia técnica."}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Optimizan tiempos de análisis, reducir errores en la interpretación normativa y fortalecer la fundamentación legal de los avalúos."}]}]},{"tagName":"p","type":"text","components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Enlaces:"}]},{"type":"textnode","content":" "},{"type":"link","attributes":{"href":"https://chatgpt.com/","target":"_blank"},"components":[{"type":"textnode","content":"https://chatgpt.com/"}]},{"type":"textnode","content":" | "},{"type":"link","attributes":{"href":"https://gemini.google.com/","target":"_blank"},"components":[{"type":"textnode","content":"https://gemini.google.com/app"}]},{"type":"textnode","content":" | "},{"type":"link","attributes":{"href":"https://claude.ai/","target":"_blank"},"components":[{"type":"textnode","content":"https://claude.ai/"}]}]},{"tagName":"p","components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"¿Cuándo usar cada una en un avalúo?"}]}]}]},{"type":"table","droppable":["tbody","thead","tfoot"],"classes":["table-compare"],"components":[{"type":"thead","draggable":["table"],"droppable":["tr"],"components":[{"type":"row","draggable":["thead","tbody","tfoot"],"droppable":["th","td"],"components":[{"tagName":"th","type":"cell","draggable":["tr"],"components":[{"type":"textnode","content":"ChatGPT"}]},{"tagName":"th","type":"cell","draggable":["tr"],"components":[{"type":"textnode","content":"Google Gemini"}]},{"tagName":"th","type":"cell","draggable":["tr"],"components":[{"type":"textnode","content":"Claude"}]}]}]},{"type":"tbody","draggable":["table"],"droppable":["tr"],"components":[{"type":"row","draggable":["thead","tbody","tfoot"],"droppable":["th","td"],"components":[{"type":"cell","draggable":["tr"],"components":[{"type":"textnode","content":"Elaborar informes valuatorios"},{"tagName":"br","void":true},{"type":"textnode","content":"Redactar conclusiones técnicas"},{"tagName":"br","void":true},{"type":"textnode","content":"Crear descripciones de inmuebles"},{"tagName":"br","void":true},{"type":"textnode","content":"Explicar métodos comparativos, físico o de capitalización"},{"tagName":"br","void":true},{"type":"textnode","content":"Diseñar formatos y plantillas"},{"tagName":"br","void":true},{"type":"textnode","content":"Capacitación y docencia en valuación"}]},{"type":"cell","draggable":["tr"],"components":[{"type":"textnode","content":"Trabajar con Google Sheets"},{"tagName":"br","void":true},{"type":"textnode","content":"Automatizar bases de comparables"},{"tagName":"br","void":true},{"type":"textnode","content":"Analizar tablas"},{"tagName":"br","void":true},{"type":"textnode","content":"Integrarse con Drive, Gmail y Docs"},{"tagName":"br","void":true},{"type":"textnode","content":"Obtener apoyo rápido con información web"}]},{"type":"cell","draggable":["tr"],"components":[{"type":"textnode","content":"Leer documentos muy largos"},{"tagName":"br","void":true},{"type":"textnode","content":"Revisar normatividad"},{"tagName":"br","void":true},{"type":"textnode","content":"Detectar inconsistencias"},{"tagName":"br","void":true},{"type":"textnode","content":"Comparar contratos o escrituras"},{"tagName":"br","void":true},{"type":"textnode","content":"Analizar manuales técnicos completos"}]}]},{"type":"row","draggable":["thead","tbody","tfoot"],"droppable":["th","td"],"components":[{"type":"cell","draggable":["tr"],"components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Ejemplo práctico:"}]},{"type":"textnode","content":" \"Redacta la conclusión de un avalúo habitacional en Toluca con enfoque comparativo de mercado\"."}]},{"type":"cell","draggable":["tr"],"components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Ejemplo práctico:"}]},{"type":"textnode","content":" \"Analiza esta hoja de comparables y calcula promedio, desviación y valor ajustado\"."}]},{"type":"cell","draggable":["tr"],"components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Ejemplo práctico:"}]},{"type":"textnode","content":" \"Resume esta escritura de 120 páginas y detecta limitaciones de dominio relevantes para el avalúo\"."}]}]},{"type":"row","draggable":["thead","tbody","tfoot"],"droppable":["th","td"],"components":[{"type":"cell","draggable":["tr"],"components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Ventaja principal:"}]},{"type":"textnode","content":" Produce textos profesionales y organizados con muy buena presentación."}]},{"type":"cell","draggable":["tr"],"components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Ventaja principal:"}]},{"type":"textnode","content":" Productividad dentro del ecosistema Google."}]},{"type":"cell","draggable":["tr"],"components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Ventaja principal:"}]},{"type":"textnode","content":" Maneja grandes volúmenes de texto con mucha claridad."}]}]}]}]},{"classes":["actividad-box"],"components":[{"tagName":"i","classes":["fas","fa-tasks"]},{"type":"textnode","content":" "},{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Actividad 1.1:"}]},{"tagName":"br","void":true},{"type":"textnode","content":"Generar con IA (ChatGPT): \"Define valor comercial conforme a normativa mexicana\""},{"tagName":"br","void":true},{"type":"textnode","content":"- Resultado esperado: Identificar diferencias entre respuesta IA vs criterio técnico real\n                    "},{"type":"button","classes":["btn-demo"],"attributes":{"type":"button","id":"simularAct1_1"},"components":[{"type":"contentEditable","components":[{"tagName":"i","classes":["fas","fa-comment"]},{"type":"textnode","content":" Simular respuesta IA"}]}]},{"attributes":{"id":"demoAct1_1"}}]},{"classes":["actividad-box"],"components":[{"tagName":"strong","type":"text","components":[{"tagName":"i","classes":["fas","fa-map-marker-alt"]},{"type":"textnode","content":" Ejercicio práctico:"}]},{"tagName":"br","void":true},{"type":"textnode","content":"A partir de la dirección física de un inmueble, generar con IA (ChatGPT) la:"},{"tagName":"br","void":true},{"type":"textnode","content":"- Longitud y latitud geográfica del inmueble"},{"tagName":"br","void":true},{"type":"textnode","content":"- Coordenadas UTM"},{"tagName":"br","void":true},{"type":"textnode","content":"- Altitud geográfica del inmueble"},{"tagName":"br","void":true},{"tagName":"br","void":true},{"type":"textnode","content":"Ejemplo: Boulevard Toluca - Metepec, No. 267, Colonia la michoacana, Metepec, Estado de Mexico\n                    "},{"type":"button","classes":["btn-demo"],"attributes":{"type":"button","id":"simularCoordenadas"},"components":[{"type":"contentEditable","components":[{"tagName":"i","classes":["fas","fa-globe"]},{"type":"textnode","content":" Simular datos geo IA"}]}]},{"attributes":{"id":"geoDemo"}}]}]},{"classes":["subtema-card"],"components":[{"tagName":"h3","type":"heading","components":[{"tagName":"i","classes":["fas","fa-shield-alt"]},{"type":"textnode","content":" 1.2.- Ética y responsabilidad del perito"}]},{"classes":["texto-completo"],"components":[{"tagName":"p","components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"La IA como herramienta de apoyo en avalúos"}]}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"La Inteligencia Artificial (IA) se utiliza como herramienta auxiliar en el proceso de valuación inmobiliaria, sin sustituir el criterio profesional del perito valuador."}]},{"tagName":"p","components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Riesgos en el uso de IA en avalúos"}]}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"El uso de IA en valuación inmobiliaria conlleva riesgos que deben ser controlados:"}]},{"tagName":"ul","classes":["lista-viñetas"],"components":[{"tagName":"li","type":"text","components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Errores en la información:"}]},{"type":"textnode","content":" Interpretaciones incorrectas de normativas, valores o datos de mercado."}]},{"tagName":"li","type":"text","components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Sesgos en datos comparables:"}]},{"type":"textnode","content":" Resultados influenciados por información incompleta o no representativa del entorno inmobiliario."}]},{"tagName":"li","type":"text","components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Uso indebido de información:"}]},{"type":"textnode","content":" Se recomienda verificar el tipo de información compartida con la IA, para evitar el manejo inadecuado de datos sensibles del inmueble o del cliente."}]},{"tagName":"li","type":"text","components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Dependencia tecnológica:"}]},{"type":"textnode","content":" Uso excesivo de la IA sin validación técnica."}]}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"Estos riesgos pueden afectar la confiabilidad del avalúo si no se supervisan adecuadamente."}]},{"tagName":"p","components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Responsabilidad del perito valuador"}]}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"El perito valuador mantiene la responsabilidad total sobre el avalúo emitido, independientemente del uso de herramientas de IA. En este sentido, debe:"}]},{"tagName":"ul","classes":["lista-viñetas"],"components":[{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Verificar la información generada por la IA con fuentes oficiales (catastro, normativas locales, registros)."}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Validar el cumplimiento de la normatividad aplicable."}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Aplicar metodologías valuatorias reconocidas."}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Emitir conclusiones fundamentadas bajo criterio técnico y experiencia profesional."}]}]},{"tagName":"p","components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"\"La IA es un apoyo, pero no sustituye la firma ni la responsabilidad legal del perito. (IVS)\""}]}]},{"tagName":"p","components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Principios éticos en avalúos con IA"}]}]},{"tagName":"ul","classes":["lista-viñetas"],"components":[{"tagName":"li","type":"text","components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Confidencialidad:"}]},{"type":"textnode","content":" Protección de la información del inmueble, del cliente y de los documentos utilizados en el avalúo, evitando su exposición en plataformas digitales sin control."}]},{"tagName":"li","type":"text","components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Transparencia:"}]},{"type":"textnode","content":" Claridad en la metodología empleada, fuentes de información y, en su caso, el uso de herramientas de IA como apoyo en el análisis."}]},{"tagName":"li","type":"text","components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Trazabilidad:"}]},{"type":"textnode","content":" Registro documentado de datos, fuentes, procedimientos y cálculos utilizados en el avalúo, permitiendo su revisión y validación por terceros."}]}]}]},{"classes":["imagen-referencia"],"components":[{"type":"svg","resizable":{"ratioDefault":true},"attributes":{"width":"100%","height":"80","viewBox":"0 0 500 80","xmlns":"http://www.w3.org/2000/svg"},"components":[{"tagName":"rect","type":"svg-in","resizable":{"ratioDefault":true},"attributes":{"width":"500","height":"80","fill":"#eef3fc","rx":"15"}},{"tagName":"text","type":"svg-in","resizable":{"ratioDefault":true},"attributes":{"x":"250","y":"32","font-family":"Inter","font-size":"13","font-weight":"bold","fill":"#1a4a5f","text-anchor":"middle"},"components":[{"type":"textnode","content":"Principios Éticos: Confidencialidad • Transparencia • Trazabilidad"}]},{"tagName":"text","type":"svg-in","resizable":{"ratioDefault":true},"attributes":{"x":"250","y":"55","font-family":"Inter","font-size":"11","fill":"#2e6a80","text-anchor":"middle"},"components":[{"type":"textnode","content":"El perito mantiene el control total del dictamen"}]}]}]},{"classes":["actividad-box"],"components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Actividad 1.2:"}]},{"tagName":"br","void":true},{"type":"textnode","content":"Análisis de un texto generado por IA con errores"},{"tagName":"br","void":true},{"type":"textnode","content":"- Resultado esperado: Identificación de riesgos y corrección de información\n                    "},{"type":"button","classes":["btn-demo"],"attributes":{"type":"button","id":"mostrarErrorEtica"},"components":[{"type":"contentEditable","components":[{"tagName":"i","classes":["fas","fa-eye"]},{"type":"textnode","content":" Mostrar ejemplo con errores"}]}]},{"attributes":{"id":"errorEticaDemo"}}]}]}]},{"type":"comment","content":" TEMA 2 - COMPLETO CON TODA LA INFORMACIÓN DEL WORD "},{"classes":["pagina-tema"],"attributes":{"id":"pagina-tema2"},"components":[{"classes":["tema-header"],"components":[{"tagName":"h2","type":"heading","components":[{"tagName":"i","classes":["fas","fa-user-astronaut"]},{"type":"textnode","content":" 2. Creación de agentes de IA (Gems de Gemini / GPTs)"}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"Configuración de agentes con perfil de perito, Knowledge Base, actividades prácticas."}]}]},{"type":"comment","content":" ¿Qué es un agente de IA? - texto completo "},{"classes":["subtema-card"],"components":[{"tagName":"h3","type":"heading","components":[{"tagName":"i","classes":["fas","fa-robot"]},{"type":"textnode","content":" ¿Qué es un agente de IA?"}]},{"classes":["texto-completo"],"components":[{"tagName":"p","type":"text","components":[{"type":"textnode","content":"Un agente de Inteligencia Artificial en el ámbito de avalúos inmobiliarios es un sistema configurado para apoyar de manera automatizada en tareas específicas del proceso valuatorio, como el análisis normativo, la revisión de información del inmueble y la generación de reportes técnicos. Opera bajo criterios definidos por el perito valuador, permitiendo estandarizar procesos y mejorar la eficiencia sin sustituir el juicio profesional."}]}]},{"classes":["imagen-referencia"],"components":[{"type":"svg","resizable":{"ratioDefault":true},"attributes":{"width":"100%","height":"90","viewBox":"0 0 500 90","xmlns":"http://www.w3.org/2000/svg"},"components":[{"tagName":"rect","type":"svg-in","resizable":{"ratioDefault":true},"attributes":{"width":"500","height":"90","fill":"#f0f7fc","rx":"16"}},{"tagName":"text","type":"svg-in","resizable":{"ratioDefault":true},"attributes":{"x":"250","y":"35","font-family":"Inter","font-size":"12","font-weight":"bold","fill":"#1a4a5f","text-anchor":"middle"},"components":[{"type":"textnode","content":"Arquitectura Agente IA: Instrucción + Knowledge Base + Respuesta Técnica"}]},{"tagName":"text","type":"svg-in","resizable":{"ratioDefault":true},"attributes":{"x":"250","y":"60","font-family":"Inter","font-size":"10","fill":"#2e6a80","text-anchor":"middle"},"components":[{"type":"textnode","content":"No sustituye al perito • Apoyo en dictámenes"}]}]}]}]},{"type":"comment","content":" 2.1 Configuración de un agente con el \"perfil de perito\" - texto completo "},{"classes":["subtema-card"],"components":[{"tagName":"h3","type":"heading","components":[{"tagName":"i","classes":["fas","fa-sliders-h"]},{"type":"textnode","content":" 2.1. Configuración de un agente con el \"perfil de perito\""}]},{"classes":["texto-completo"],"components":[{"tagName":"p","type":"text","components":[{"type":"textnode","content":"El agente de IA debe configurarse con un rol claramente definido dentro del proceso de valuación inmobiliaria, simulando funciones específicas del perito valuador, como analista normativo, auxiliar técnico o redactor de informes. Este rol determina el tipo de respuestas, el enfoque metodológico y el nivel de detalle requerido, asegurando que la información generada sea coherente con la práctica profesional del avalúo."}]},{"tagName":"p","components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Diseño del comportamiento"}]}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"El comportamiento del agente debe estructurarse mediante instrucciones precisas que definan cómo analizar la información, qué criterios aplicar y cómo responder ante distintos escenarios. En valuación, esto implica establecer lineamientos como:"}]},{"tagName":"ul","classes":["lista-viñetas"],"components":[{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Priorizar normativa vigente y fuentes oficiales"}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Seguir metodologías valuatorias reconocidas"}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Mantener consistencia en el análisis de datos"}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Solicitar información faltante cuando sea necesario"}]}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"Un diseño adecuado permite obtener resultados más confiables y alineados con el proceso técnico del avalúo."}]},{"tagName":"p","components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Lenguaje técnico-formal"}]}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"El agente debe emplear un lenguaje técnico, claro y formal, acorde a los estándares utilizados en reportes de valuación inmobiliaria. Esto incluye:"}]},{"tagName":"ul","classes":["lista-viñetas"],"components":[{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Uso de terminología especializada (valor comercial, uso de suelo, coeficiente de ocupación, etc.)"}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Redacción estructurada y objetiva"}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Evitar ambigüedades o interpretaciones subjetivas"}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Presentar conclusiones fundamentadas"}]}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"El uso correcto del lenguaje fortalece la calidad profesional del informe generado."}]},{"tagName":"p","components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Límites del agente"}]}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"El agente de IA debe operar dentro de límites claramente definidos para evitar errores o usos inadecuados. En valuación inmobiliaria, estos límites incluyen:"}]},{"tagName":"ul","classes":["lista-viñetas"],"components":[{"tagName":"li","type":"text","components":[{"type":"textnode","content":"No sustituir el criterio ni la responsabilidad del perito valuador"}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"No emitir conclusiones definitivas sin validación profesional"}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"No utilizar información no verificada o no oficial"}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Respetar la confidencialidad de los datos del cliente y del inmueble"}]}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"El establecimiento de estos límites garantiza un uso ético, responsable y técnicamente adecuado de la IA en el proceso de avalúo."}]}]},{"type":"comment","content":" Actividad 2.1 con el ejemplo completo del menú de opciones "},{"classes":["actividad-box"],"components":[{"tagName":"strong","type":"text","components":[{"tagName":"i","classes":["fas","fa-tasks"]},{"type":"textnode","content":" Actividad 2.1:"}]},{"tagName":"br","void":true},{"type":"textnode","content":"\n                    Crear una gema en GEMINI."},{"tagName":"br","void":true},{"type":"textnode","content":"\n                    El prompt de la instrucción base del agente (GEMA) con: Rol, función, estilo y restricciones."},{"tagName":"br","void":true},{"tagName":"br","void":true},{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Ejemplo del documento:"}]},{"type":"textnode","content":" Genera un prompt que sirva para una aplicación sobre como generar los formatos de avalúos correspondientes a bienes inmuebles del estado de México, México. Con las gacetas, comunicados, informes y leyes oficiales actuales al 2026."},{"tagName":"br","void":true},{"tagName":"br","void":true},{"type":"textnode","content":"\n                    La aplicación (Gema en Gemini) deberá iniciar solicitando la ubicación del inmueble, a partir de esa información se deberá arrojar la información solicitada."},{"tagName":"br","void":true},{"tagName":"br","void":true},{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Colocar un menú de opciones:"}]},{"type":"text","classes":["menu-ejemplo"],"components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"1.- ubicación del inmueble:"}]},{"type":"textnode","content":" Calle, numero, aceras que ven al, entre las calles de, colonia, CP, Delegación o municipio, ciudad o población, estado, en caso de existir en la web una publicación con el valor comercial de ese inmueble colocarlos o dejar el campo libre para que el perito lo coloque de manera manual."},{"tagName":"br","void":true},{"tagName":"br","void":true},{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"2.- Antecedentes:"}]},{"type":"textnode","content":" Fecha del avaluó (fecha en la que se genera la información), inmueble que se valúa (tipo: casa habitación, negocio, etc.), Longitud y latitud geográfica del inmueble, Coordenadas UTM, Altitud geográfica del inmueble, Vías de acceso e importancia de estas, Infraestructura disponible en la zona, Otros Servicios, Equipamiento urbano, Contaminación ambiental, Área total del terreno (en m² según)."},{"tagName":"br","void":true},{"tagName":"br","void":true},{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"3.- Consideraciones:"}]},{"type":"textnode","content":" Enfoque de costo, Enfoque de renta, Enfoque de comparación.\n                    "}]},{"type":"button","classes":["btn-demo"],"attributes":{"type":"button","id":"verPromptCompleto"},"components":[{"type":"contentEditable","components":[{"tagName":"i","classes":["fas","fa-terminal"]},{"type":"textnode","content":" Ver prompt estructurado"}]}]},{"attributes":{"id":"promptCompletoDemo"}}]}]},{"type":"comment","content":" 2.2 Carga de Knowledge Base - texto completo "},{"classes":["subtema-card"],"components":[{"tagName":"h3","type":"heading","components":[{"tagName":"i","classes":["fas","fa-database"]},{"type":"textnode","content":" 2.2. Carga de Knowledge Base"}]},{"classes":["texto-completo"],"components":[{"tagName":"p","type":"text","components":[{"type":"textnode","content":"En el contexto de los avalúos inmobiliarios, una base de conocimiento es el conjunto estructurado de información técnica, normativa y metodológica que sirve como referencia para la elaboración de dictámenes valuatorios. Incluye leyes, reglamentos, normas, manuales técnicos, criterios metodológicos y datos de mercado, los cuales permiten al perito valuador fundamentar sus análisis, garantizar la validez de sus conclusiones y asegurar el cumplimiento de la normatividad vigente."}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"En el uso de IA, la base de conocimiento permite que los agentes generen respuestas alineadas con criterios oficiales y prácticas profesionales del avalúo."}]},{"tagName":"p","components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Ley General de Bienes Nacionales"}]}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"Es el marco legal que regula la administración, valuación y disposición de los bienes propiedad de la nación."}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"En el ámbito de los avalúos, esta ley:"}]},{"tagName":"ul","classes":["lista-viñetas"],"components":[{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Establece las bases para la valuación de bienes nacionales"}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Define atribuciones de las autoridades competentes"}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Regula procesos de adquisición, enajenación y uso de bienes"}]}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"Su conocimiento es fundamental para asegurar que los avalúos cumplan con disposiciones legales aplicables en el sector público."}]},{"tagName":"p","components":[{"tagName":"strong","type":"text","components":[{"type":"textnode","content":"Manuales de Procedimientos Técnicos"}]}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"Son documentos normativos que establecen los lineamientos metodológicos para la elaboración de avalúos inmobiliarios."}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"En particular, estos manuales:"}]},{"tagName":"ul","classes":["lista-viñetas"],"components":[{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Definen enfoques de valuación (comparativo, de ingresos, de costos)"}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Establecen criterios técnicos para el análisis del inmueble"}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Determinan la estructura y contenido de los reportes"}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Garantizan uniformidad y calidad en los avalúos"}]}]},{"tagName":"p","type":"text","components":[{"type":"textnode","content":"Su aplicación permite que los dictámenes valuatorios sean consistentes, verificables y alineados con estándares profesionales."}]}]},{"classes":["actividad-box"],"components":[{"tagName":"strong","type":"text","components":[{"tagName":"i","classes":["fas","fa-tasks"]},{"type":"textnode","content":" Actividad 2.2:"}]},{"tagName":"br","void":true},{"type":"textnode","content":"\n                    Cargar los documentos necesarios en el agente (Gema) previamente creada y solicitar al agente:"},{"tagName":"br","void":true},{"type":"textnode","content":"\n                    - Explicar un artículo"},{"tagName":"br","void":true},{"type":"textnode","content":"\n                    - Aplicarlo a un caso valuatorio\n                    "},{"type":"button","classes":["btn-demo"],"attributes":{"type":"button","id":"simularArticuloKB"},"components":[{"type":"contentEditable","components":[{"tagName":"i","classes":["fas","fa-gavel"]},{"type":"textnode","content":" Simular: explicar artículo LGBN y caso valuatorio"}]}]},{"attributes":{"id":"resultadoKB"}}]}]}]}]},{"tagName":"footer","type":"text","components":[{"tagName":"i","classes":["fas","fa-file-alt"]},{"type":"textnode","content":" Contenido 100% textual del archivo Módulo1_DiplomadoVf.docx | UAEMéx-FECOVAL | Tema 2 completo con toda la información del documento original\n    "}]}]},{"type":"script","components":[{"type":"textnode","content":"\n    const btnInicio = document.querySelector('[data-page=\"inicio\"]');\n    const btnTema1 = document.querySelector('[data-page=\"tema1\"]');\n    const btnTema2 = document.querySelector('[data-page=\"tema2\"]');\n    const paginaInicio = document.getElementById('pagina-inicio');\n    const paginaTema1 = document.getElementById('pagina-tema1');\n    const paginaTema2 = document.getElementById('pagina-tema2');\n\n    function mostrarPagina(page) {\n        paginaInicio.classList.remove('active-page');\n        paginaTema1.classList.remove('active-page');\n        paginaTema2.classList.remove('active-page');\n        btnInicio.classList.remove('active');\n        btnTema1.classList.remove('active');\n        btnTema2.classList.remove('active');\n        if (page === 'inicio') { paginaInicio.classList.add('active-page'); btnInicio.classList.add('active'); }\n        else if (page === 'tema1') { paginaTema1.classList.add('active-page'); btnTema1.classList.add('active'); }\n        else if (page === 'tema2') { paginaTema2.classList.add('active-page'); btnTema2.classList.add('active'); }\n    }\n    btnInicio.addEventListener('click', () => mostrarPagina('inicio'));\n    btnTema1.addEventListener('click', () => mostrarPagina('tema1'));\n    btnTema2.addEventListener('click', () => mostrarPagina('tema2'));\n\n    document.getElementById('simularAct1_1')?.addEventListener('click', () => {\n        const div = document.getElementById('demoAct1_1');\n        div.style.display = 'block';\n        div.innerHTML = \"<strong>🤖 Respuesta IA simulada:</strong> 'Valor comercial conforme a normativa mexicana: Es el monto estimado por el cual un inmueble se transaría voluntariamente entre comprador y vendedor, en condiciones de libre mercado, según LGBN y SHF.'<br><span style='color:#b5470a;'>✅ Contraste técnico: El perito debe ajustar por análisis de mercado local, validar restricciones de uso de suelo y aplicar criterios de homologación.</span>\";\n    });\n    document.getElementById('simularCoordenadas')?.addEventListener('click', () => {\n        const geo = document.getElementById('geoDemo');\n        geo.style.display = 'block';\n        geo.innerHTML = \"📍 Latitud: 19.2789, Longitud: -99.6112<br>🗺️ Coordenadas UTM: 14Q 443678 2134567<br>⛰️ Altitud: 2,620 msnm<br><small>Datos generados por IA a manera de ejemplo. Validar con INEGI o catastro municipal.</small>\";\n    });\n    document.getElementById('mostrarErrorEtica')?.addEventListener('click', () => {\n        const err = document.getElementById('errorEticaDemo');\n        err.style.display = 'block';\n        err.innerHTML = \"<strong>📄 Texto generado por IA con errores:</strong> 'El valor comercial se obtiene solo con costo de reposición menos depreciación. No se requiere verificar uso de suelo ni inspección.'<br>❌ Errores: Omisión de enfoques de mercado/ingresos, falta de validación normativa. ✅ Corrección: Aplicar métodos reconocidos y supervisión profesional.\";\n    });\n    document.getElementById('verPromptCompleto')?.addEventListener('click', () => {\n        const pr = document.getElementById('promptCompletoDemo');\n        pr.style.display = 'block';\n        pr.innerHTML = \"<strong>📌 PROMPT BASE PARA GEMA (Actividad 2.1 - textual documento):</strong><br><br>'Eres un agente especializado en avalúos del Estado de México. Inicia solicitando ubicación del inmueble (calle, número, colonia, CP, municipio).<br><br>Menú de opciones:<br>1) Ubicación: Calle, numero, colonia, CP, Delegación, estado, valor comercial web (opcional).<br>2) Antecedentes: Fecha del avalúo, tipo de inmueble, coordenadas UTM, altitud, vías de acceso, infraestructura, contaminación, área total.<br>3) Consideraciones: Enfoque de costo, renta y comparación.<br><br>Lenguaje técnico-formal. No sustituir criterio del perito.'\";\n    });\n    document.getElementById('simularArticuloKB')?.addEventListener('click', () => {\n        const kb = document.getElementById('resultadoKB');\n        kb.style.display = 'block';\n        kb.innerHTML = \"<strong>📖 Agente con Knowledge Base (Ley General de Bienes Nacionales):</strong><br><br><strong>Artículo 32 LGBN:</strong> 'Las valuaciones de bienes inmuebles propiedad de la Nación se realizarán conforme a métodos reconocidos por la legislación aplicable y considerando el valor de mercado.'<br><br><strong>Caso valuatorio:</strong> Terreno federal en Zona Metepec. El agente asiste en la redacción del fundamento legal; el perito aplica enfoque comparativo, verifica fuentes catastrales y emite dictamen bajo su responsabilidad.\";\n    });\n"}]},{"type":"custom-html-body","attributes":{"data-custom-html-body":true}}],"doctype":"<!DOCTYPE html>","head":{"type":"head","components":[{"tagName":"meta","void":true,"attributes":{"charset":"UTF-8"}},{"tagName":"meta","void":true,"attributes":{"name":"viewport","content":"width=device-width, initial-scale=1.0, user-scalable=yes"}},{"tagName":"title","type":"text","components":[{"type":"textnode","content":"Diplomado IA Valuación | UAEMéx-FECOVAL - Módulo 1 Completo"}]},{"tagName":"link","void":true,"attributes":{"href":"https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,600;14..32,700;14..32,800&display=swap","rel":"stylesheet"}},{"tagName":"link","void":true,"attributes":{"rel":"stylesheet","href":"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"}}]},"docEl":{"tagName":"html","attributes":{"lang":"es-MX"}}},"id":"iNuEKeKokvGiCg43","minHeight":"500px"}],"id":"0pjBOn5oyG8NzUGW","settings":{"slug":"","socialTitle":""}},{"name":"Sesion 2","frames":[{"component":{"type":"wrapper","classes":["gjs-t-body"],"components":[{"name":"Page Wrapper","classes":["page-wrapper"],"components":[{"name":"App Container","classes":["soft-shadow","app-container"],"components":[{"tagName":"header","name":"Main Header","classes":["main-header"],"components":[{"name":"Header Content","classes":["header-content"],"components":[{"name":"Header Title Group","classes":["header-title-group"],"components":[{"tagName":"p","type":"text","name":"Header Eyebrow","classes":["header-eyebrow"],"components":[{"type":"textnode","content":"UAEMéx · FECOVAL"}]},{"type":"heading","name":"Header Title",